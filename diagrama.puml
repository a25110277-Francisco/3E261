class Usuario {
    - Heroe heroe
    + guardarPartida(Nivel)
    + cargarPartida(Nivel)
    + seleccionarHeroe(Heroe)
}

class Vida{
    + perder(Vida)
    + ganar(Vida)
}

class Personaje{
    + caminar()
    + caer()
    - Vida vida
}

class Heroe{
    - Tuberia tuberia
    + Item item
    - PowerUp poweUp
    + saltar()
    + agacharse()
    + correr()
    + recoger(Item)
    + recibirDano()
    + entrarTuberia(Tuberia)
}

class Enemigo {
    + morir()
    + atacar()
    + cambiarDireccion()
}

class Jefe {
    + usarHabilidadEspecial()
    + enfurecer()
}

class Bloque{
    - Item contenido
    + golpear()
    + Item : liberar()
}

class Tuberia{
    + Nivel : Ingresar(Heroe)
    - Nivel entrada
    - Nivel salida
}

class Moneda{
    + Puntos : sumarPuntos(Monedas)
}

class PowerUp{
    + activar(Heroe)
}

class Mundo {
    + iniciarNivel()
    + avanzarNivel()
    + derrotarJefeMundo()
}

class Nivel {
    + iniciarNivel()
    + finalizarNivel()
    + pausar()
}

class Temporizador {
    Segundo segundo
    + iniciar()
    + detener()
}

@enduml