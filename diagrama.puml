class Usuario {
    - Heroe heroe
    + guardarPartida()
    + cargarPartida()
    + seleccionarHeroe(Heroe)
}

class Vida{
    + perder()
    + ganar()
}

class Personaje{
    - Vida vida
}

class Heroe{
    + Recoger(Item)
    - PowerUp poweUp
    + saltar()
    + agacharse()
    + correr()
    + recoger(Item item)
    + recibirDano()
    + entrarTuberia(Tuberia)
}

class Enemigo {
    + morir()
    + atacar()
    + cambiarDireccion()
}

class Jefe {
    + usarHabilidadEspecial()
    + enfurecer()
}

class Bloque{
    - Item : contenido
    + golpear()
    + Item : liberar()
}

class Tuberia{
    + Nivel : Ingresar(Heroe)
    - Nivel entrada
    - Nivel salida
}

class Moneda{
    + Puntos : sumarPuntos()
}

class PowerUp{
    + activar(Heroe)
}

class Nivel{
    + iniciarNivel()
    + finalizarNivel()
}

class Mundo{
    + iniciarNivel()
    + avanzarNivel()
}

@enduml